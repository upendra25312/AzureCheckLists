{
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Frame-Options": "DENY",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/data/*",
      "/_next/*",
      "/*.css",
      "/*.js",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.svg"
    ]
  },
  "routes": [
    {
      "route": "/admin*",
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/api/admin*",
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/api/review-records",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/review-records/export",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-review-state",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews/activate",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/data/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ]
}
