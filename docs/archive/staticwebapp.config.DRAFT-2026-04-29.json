{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "admin"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated", "admin"]
    }
  ],
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/<tenant-id>/v2.0"
        }
      }
    }
  }
}
